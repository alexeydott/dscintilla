procedure SetSelectionNCaretVirtualSpace(ASelection: Integer; ASpace: NativeInt);
procedure %s.SetSelectionNCaretVirtualSpace(ASelection: Integer; ASpace: NativeInt);
begin
  if (ASelection >= 0) and (ASelection < GetSelections) then
    SendEditor(SCI_SETSELECTIONNCARETVIRTUALSPACE, ASelection, ASpace);
end;

