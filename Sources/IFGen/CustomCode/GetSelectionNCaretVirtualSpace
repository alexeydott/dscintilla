function GetSelectionNCaretVirtualSpace(ASelection: Integer): NativeInt;
function %s.GetSelectionNCaretVirtualSpace(ASelection: Integer): NativeInt;
begin
  if (ASelection >= 0) and (ASelection < GetSelections) then
    Result := SendEditor(SCI_GETSELECTIONNCARETVIRTUALSPACE, ASelection, 0)
  else
    Result := INVALID_POSITION;
end;

