function GetSelectionNAnchorVirtualSpace(ASelection: Integer): NativeInt;
function %s.GetSelectionNAnchorVirtualSpace(ASelection: Integer): NativeInt;
begin
  if (ASelection >= 0) and (ASelection < GetSelections) then
    Result := SendEditor(SCI_GETSELECTIONNANCHORVIRTUALSPACE, ASelection, 0)
  else
    Result := INVALID_POSITION;
end;

