procedure SetSelectionNAnchorVirtualSpace(ASelection: Integer; ASpace: NativeInt);
procedure %s.SetSelectionNAnchorVirtualSpace(ASelection: Integer; ASpace: NativeInt);
begin
  if (ASelection >= 0) and (ASelection < GetSelections) then
    SendEditor(SCI_SETSELECTIONNANCHORVIRTUALSPACE, ASelection, ASpace);
end;

